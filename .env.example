# Groq LLM API (reused from IntelliRAG)
GROQ_API_KEY=your_groq_api_key_here

# Google Places API - for dynamic doctor directory fallback (any city not in curated list)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Google Programmable Search Engine - Tier 2 fallback scoped to practo.com
GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
GOOGLE_CSE_ENGINE_ID=your_search_engine_id_here

# App config
APP_ENV=development
LOG_LEVEL=INFO
